{
  "name": "rule-poc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "// dev": "====================",
    "dev": "vite",
    "dev:server": "set TS_NODE_PROJECT=tsconfig.server.json&& node --loader ts-node/esm --no-warnings server/index.ts",
    "dev:all": "powershell -ExecutionPolicy Bypass -File .\\dev.ps1",
    "stop": "powershell -ExecutionPolicy Bypass -File .\\stop.ps1",
    "// build": "====================",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:all": "npm run build:server && npm run build:client",
    "// start": "====================",
    "start:server": "node dist-server/index.js",
    "start": "npm run start:server",
    "// misc": "====================",
    "clean": "powershell -NoProfile -Command \"Remove-Item -Recurse -Force dist,dist-server,.dev.pids.json -ErrorAction SilentlyContinue\"",
    "preview": "vite preview",
    "lint": "eslint .",
    "prod": "powershell -ExecutionPolicy Bypass -File .\\start.ps1"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "npm:rolldown-vite@7.2.5"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  },
  "engines": {
    "node": "20.x"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": [
      "vite/client"
    ]
  },
  "ts-node": {
    "esm": true,
    "transpileOnly": true
  }
}
